# =============================================================================
# DebuggerMind - Environment Configuration
# =============================================================================
# Copy this file to .env.local for development
# Copy this file to .env.production for production
# Update with your actual values
# DO NOT commit .env.local or .env.production to version control
# =============================================================================

# -----------------------------------------------------------------------------
# API CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# Your backend API base URL
# Example: https://api.yourdomain.com or http://localhost:8000
API_BASE_URL=https://example-api.com

# Your backend API v1 endpoint
# Example: https://api.yourdomain.com/api/v1 or http://localhost:8000/api/v1
API_BASE_URL_V1=https://example-api.com/api/v1

# -----------------------------------------------------------------------------
# SITE CONFIGURATION (OPTIONAL)
# -----------------------------------------------------------------------------
# Your site's public URL (used for SEO and metadata)
# Example: https://yourdomain.com or http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# ENVIRONMENT (OPTIONAL)
# -----------------------------------------------------------------------------
# Current environment: development, production, or test
# Default: development
NODE_ENV=development

# -----------------------------------------------------------------------------
# ANALYTICS & TRACKING (OPTIONAL)
# -----------------------------------------------------------------------------
# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com/ → Admin → Data Streams
# Format: G-XXXXXXXXXX
# Leave empty to disable Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Meta Pixel ID (Facebook Pixel)
# Get from: https://business.facebook.com/events_manager → Settings
# Format: numeric ID (e.g., 1234567890123456)
# Leave empty to disable Meta Pixel tracking
NEXT_PUBLIC_META_PIXEL_ID=

# -----------------------------------------------------------------------------
# ADDITIONAL NOTES
# -----------------------------------------------------------------------------
# - All environment variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Other variables are only available on the server side
# - Restart the development server after changing this file
# - For production, set these in your hosting platform's environment settings
# =============================================================================
