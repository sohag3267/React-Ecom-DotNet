    "next": "15.5.7",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-day-picker": "^9.11.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "react-i18next": "^15.7.3",
    "react-is": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "^3.2.1",
